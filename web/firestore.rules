rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Web 2.5 Architecture:
    // All writes are handled securely via Cloud Functions or indexers using the Admin SDK, which bypasses these rules.
    // All reads are public, mirroring the public nature of Web3 on-chain data.
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profiles: Only the user can read or write their own profile document
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Products: Authenticated users can read (customers scan products), but only the owner merchant can write
    match /products/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    
    // Receipts: Merchant records the receipt. Accessible by the merchant owner or involved customer.
    match /receipts/{receiptId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid || 
        resource.data.merchantAddress == request.auth.uid // fallback
      );
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    
    // Purchases: Only the customer who made the purchase can read/write their purchase log
    match /purchases/{purchaseId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    
    // Stores: Publicly readable for map discovery. Writes are done exclusively by the Cloud Function indexer.
    match /stores/{storeId} {
      allow read: if true;
      allow write: if false;
      allow update: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedWallet == storeId;

      // Nested Products subcollection
      match /products/{productId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
        allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      }

      // Nested Receipts subcollection
      match /receipts/{receiptId} {
        allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
        allow read: if request.auth != null && (
          resource.data.uid == request.auth.uid || 
          resource.data.merchantAddress == request.auth.uid // fallback
        );
        allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      }
    }
  }
}
